         <p>Trending</p>
      </a>
      <a href="/listings?category=Rooms" class="filter <%= category === 'Rooms' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-bed"></i></div>
         <p>Rooms</p>
      </a>
       <a href="/listings?category=Beach" class="filter <%= category === 'Beach' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-umbrella-beach"></i></div>
        <p>Beach</p>
    </a>
    <a href="/listings?category=Mountains" class="filter <%= category === 'Mountains' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
    </a>
    <a href="/listings?category=Cottages" class="filter <%= category === 'Cottages' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-house-chimney"></i></div>
        <p>Cottages</p>
    </a>
    <a href="/listings?category=City View" class="filter <%= category === 'City View' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-city"></i></div>
        <p>City View</p>
    </a>
    <a href="/listings?category=Pool Villas" class="filter <%= category === 'Pool Villas' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-water-ladder"></i></div>
        <p>Pool Villas</p>
    </a>
    <a href="/listings?category=Nature Stay" class="filter <%= category === 'Nature Stay' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-leaf"></i></div>
        <p>Nature Stay</p>
    </a>
    <a href="/listings?category=Camps" class="filter <%= category === 'Camps' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camps</p>
    </a>
    <a href="/listings?category=Meals" class="filter <%= category === 'Meals' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-utensils"></i></div>
        <p>Meals</p>
    </a>
    <a href="/listings?category=Parking" class="filter <%= category === 'Parking' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-square-parking"></i></div>
        <p>Parking</p>
    </a>
    <a href="/listings?category=Pet-Friendly" class="filter <%= category === 'Pet-Friendly' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-dog"></i></div>
        <p>Pet-Friendly</p>
    </a>
    <a href="/listings?category=Luxury" class="filter <%= category === 'Luxury' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-champagne-glasses"></i></div>
        <p>Luxury</p>
    </a>
    <a href="/listings?category=Near Airport" class="filter <%= category === 'Near Airport' ? 'active-filter' : '' %>">
        <div><i class="fa-solid fa-plane-departure"></i></div>
        <p>Near Airport</p>
    </a>
    </div>

 <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-3 g-4 mt-1">
    <% if(allLists.length === 0) { %>
        <div class="col-12 text-center mt-5">
            <h3>No listings found</h3>
            <% if(search) { %>
                <p>No results for "<strong><%= search %></strong>". Try a different search.</p>
            <% } else if(category) { %>
                <p>No listings in "<strong><%= category %></strong>" yet. Try another category.</p>
            <% } else { %>
                <p>Try searching for something else.</p>
            <% } %>
            <a href="/listings" class="btn btn-outline-dark mt-2">View All Listings</a>
        </div>
    <% } else { %>
    <% for(let listing of allLists) { %>
    <div class="col">
        <div class="card homecard h-100" style="position: relative;">
            <a href="/listings/<%=listing._id%>" style="text-decoration: none;">
                <img src="<%=listing.image.url%>" class="card-img-top" alt="<%=listing.title%>" style="height: 20rem; object-fit: cover;"  />
                <div class="card-body">
                    <h5 class="card-text"><%=listing.title%></h5>
                    <p class="card-text"><%=listing.location%></p>
                    <p class="card-text" style="font-weight: bold;">&#8377;<%=listing.price.toLocaleString("en-In")%>/night</p>
                </div>
            </a>
            <% if(currUser) { %>
            <button class="wishlist-btn" data-id="<%= listing._id %>"
                onclick="toggleWishlist(event, '<%= listing._id %>')">
                <i class="<%= wishlist.includes(listing._id.toString()) ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
            </button>
            <% } %>
        </div>
    </div>
  <% } } %>
</div>

<% if(totalPages > 1) { %>
<nav aria-label="Listing pagination" class="mt-4">
  <ul class="pagination justify-content-center">
    <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
      <a class="page-link" href="/listings?page=<%= currentPage - 1 %><%= search ? '&search=' + search : '' %><%= category ? '&category=' + category : '' %>">
        &laquo; Previous
      </a>
    </li>
    <% for(let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= currentPage === i ? 'active' : '' %>">
        <a class="page-link" href="/listings?page=<%= i %><%= search ? '&search=' + search : '' %><%= category ? '&category=' + category : '' %>">
          <%= i %>
        </a>
      </li>
    <% } %>
    <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
      <a class="page-link" href="/listings?page=<%= currentPage + 1 %><%= search ? '&search=' + search : '' %><%= category ? '&category=' + category : '' %>">
        Next &raquo;
      </a>
    </li>
  </ul>
</nav>
<% } %>