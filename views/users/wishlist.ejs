<% layout("/layout/boilerplate.ejs") %>

<div class="row mt-4">
    <div class="col-10 offset-1 col-md-10 offset-md-1">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3><i class="fa-solid fa-heart" style="color: #fe424d;"></i> My Wishlist (<%= wishlistItems.length %>)</h3>
            <a href="/listings" class="btn btn-dark btn-sm">Browse Listings</a>
        </div>

        <% if(wishlistItems.length === 0) { %>
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="fa-regular fa-heart" style="font-size: 3rem; color: #ccc;"></i>
                    <h5 class="mt-3">Your wishlist is empty</h5>
                    <p class="text-muted">Tap the heart icon on any listing to save it here.</p>
                    <a href="/listings" class="btn btn-dark mt-2">Explore Listings</a>
                </div>
            </div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                <% for(let listing of wishlistItems) { %>
                    <div class="col" id="wishlist-card-<%= listing._id %>">
                        <div class="card h-100 homecard" style="position: relative;">
                            <a href="/listings/<%= listing._id %>" style="text-decoration: none;">
                                <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" style="height: 14rem; object-fit: cover;" />
                                <div class="card-body">
                                    <h6 class="card-text"><%= listing.title %></h6>
                                    <p class="card-text text-muted" style="font-size: 0.85rem;"><%= listing.location %>, <%= listing.country %></p>
                                    <p class="card-text" style="font-weight: bold;">&#8377;<%= listing.price.toLocaleString("en-In") %>/night</p>
                                </div>
                            </a>
                            <button class="wishlist-btn" data-id="<%= listing._id %>"
                                onclick="removeFromWishlist(event, '<%= listing._id %>')">
                                <i class="fa-solid fa-heart"></i>
                            </button>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>

    </div>
</div>

<script>
async function removeFromWishlist(event, listingId) {
    event.preventDefault();
    event.stopPropagation();
    try {
        const res = await fetch(`/listings/${listingId}/wishlist`, { method: 'POST' });
        if(res.ok) {
            const card = document.getElementById(`wishlist-card-${listingId}`);
            card.style.transition = 'all 0.3s ease';
            card.style.opacity = '0';
            card.style.transform = 'scale(0.8)';
            setTimeout(() => card.remove(), 300);
        }
    } catch(err) {
        console.error(err);
    }
}
</script>
